{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "command": "node .gemini/hooks/scientific-method-scripts/format-check.js",
        "timeout": 5
      },
      {
        "type": "command",
        "command": "node .gemini/hooks/scientific-method-scripts/staleness-check.js",
        "timeout": 5
      },
      {
        "type": "command",
        "command": "node .gemini/hooks/scientific-method-scripts/context-refresh.js",
        "timeout": 5
      }
    ]
  }
}
