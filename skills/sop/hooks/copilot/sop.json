{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/sop-scripts/format-check.sh",
        "powershell": ".github/hooks/sop-scripts/format-check.ps1",
        "timeout": 5
      },
      {
        "type": "command",
        "bash": ".github/hooks/sop-scripts/staleness-check.sh",
        "powershell": ".github/hooks/sop-scripts/staleness-check.ps1",
        "timeout": 5
      },
      {
        "type": "command",
        "bash": ".github/hooks/sop-scripts/context-refresh.sh",
        "powershell": ".github/hooks/sop-scripts/context-refresh.ps1",
        "timeout": 5
      }
    ]
  }
}
